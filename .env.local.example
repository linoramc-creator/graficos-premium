# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Datasource selection ---
# Acepta: "yfinance" (default) | "eodhd"
DATA_PROVIDER=yfinance

# --- EODHD (solo si DATA_PROVIDER=eodhd) ---
EODHD_API_KEY=

# --- yfinance proxy ---
# Endpoint público de Yahoo Finance (no requiere key). Si tu hosting bloquea
# llamadas a Yahoo, levanta un microservicio yfinance y apunta aquí.
YFINANCE_BASE_URL=https://query1.finance.yahoo.com
