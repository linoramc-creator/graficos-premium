# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Datasource selection ---
# Vacío = cascada automática. RECOMENDADO para Vercel.
# Acepta: "yfinance" | "stooq" | "twelvedata" | "eodhd"
DATA_PROVIDER=

# --- Twelve Data (MUY RECOMENDADO en Vercel) ---
# Yahoo bloquea las IPs de Vercel (HTTP 429) y Stooq puede devolver
# HTML/captcha desde cloud. Twelve Data tiene tier gratuito de 800
# req/día, no requiere tarjeta y funciona perfectamente desde cloud.
# Sign up: https://twelvedata.com
TWELVE_DATA_API_KEY=

# --- EODHD (alternativa premium) ---
EODHD_API_KEY=

# --- yfinance proxy ---
# Endpoint público de Yahoo Finance (no requiere key). Si tu hosting bloquea
# llamadas a Yahoo, levanta un microservicio yfinance y apunta aquí.
YFINANCE_BASE_URL=https://query1.finance.yahoo.com
